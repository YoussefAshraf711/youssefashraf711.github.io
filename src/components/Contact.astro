---

<section id="contact" class="py-20 md:py-28 px-6 relative">
  <!-- Background accent -->
  <div class="absolute inset-0 bg-gradient-to-t from-primary/[0.01] to-transparent pointer-events-none"></div>
  
  <div class="max-w-3xl mx-auto relative text-center">
    <div class="reveal">
      <p class="font-mono text-primary text-sm mb-4">04. What's Next?</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Initialize Connection
      </h2>
      <p class="text-gray-400 mb-12 max-w-md mx-auto leading-relaxed">
        Ready to build intelligent systems? Whether it's a project, collaboration, 
        or just a conversation — let's connect.
      </p>
    </div>

    <div class="reveal grid grid-cols-1 sm:grid-cols-3 gap-4">
      {contactLinks.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('mailto') ? undefined : '_blank'}
          rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          class={`group glass-card p-6 flex flex-col items-center gap-3 border border-white/[0.04] transition-all duration-500 hover:-translate-y-1 ${link.color} relative overflow-hidden`}
        >
          <div class="text-gray-400 group-hover:text-current transition-colors duration-300" set:html={link.iconSvg} />
          <span class="font-mono text-sm text-gray-300 font-medium">{link.label}</span>
          <span class="font-mono text-xs text-gray-500 truncate max-w-full">{link.value}</span>
          
          {/* Hover gradient */}
          <div class={`absolute inset-0 bg-gradient-to-br ${link.bgColor} to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-2xl`}></div>
        </a>
      ))}
    </div>

    <!-- Terminal-style message -->
    <div class="reveal mt-12">
      <p class="font-mono text-xs text-gray-600">
        <span class="text-secondary">❯</span> echo "Let's build something amazing together"
      </p>
    </div>
  </div>
</section>

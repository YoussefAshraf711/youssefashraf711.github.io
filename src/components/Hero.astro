---
---

<section class="min-h-screen flex flex-col justify-center pt-24 pb-12 relative overflow-hidden">
  <!-- Soft Background Glows -->
  <div class="absolute top-1/4 -left-20 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px] pointer-events-none mix-blend-screen opacity-50 animate-float"></div>
  <div class="absolute bottom-1/4 -right-20 w-[600px] h-[600px] bg-accent/10 rounded-full blur-[150px] pointer-events-none mix-blend-screen opacity-50 animate-float" style="animation-delay: -4s;"></div>

  <div class="max-w-5xl mx-auto px-6 lg:px-8 w-full z-10">
    <div class="space-y-8">
      <!-- Status Badge -->
      <div class="reveal inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-slate-700/50 bg-slate-800/30 backdrop-blur-sm shadow-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-secondary"></span>
        </span>
        <span class="font-medium text-slate-300 text-xs tracking-wide uppercase">
          Available for Opportunities
        </span>
      </div>

      <!-- Headlines -->
      <div class="reveal" style="transition-delay: 100ms;">
        <h1 class="text-5xl sm:text-6xl md:text-[5rem] font-bold tracking-tight leading-[1.05] text-white max-w-4xl">
          Architecting robust <br class="hidden sm:block" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-blue-400 to-accent pb-2 inline-block">
            data systems.
          </span>
        </h1>
      </div>

      <!-- Sub-headline / Text -->
      <div class="reveal max-w-2xl" style="transition-delay: 200ms;">
        <p class="text-lg md:text-xl text-slate-400 font-light leading-relaxed">
          I bridge the gap between complex software infrastructure and hardware boundaries. 
          Currently transforming data pipelines as a Trainee at <span class="text-slate-200 font-medium border-b border-primary/30 pb-0.5">DEPI</span>.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="reveal flex flex-col sm:flex-row gap-4 pt-4" style="transition-delay: 300ms;">
        <a
          href="#projects"
          class="inline-flex justify-center items-center gap-2 px-7 py-3.5 bg-white text-slate-900 font-semibold rounded-xl hover:bg-slate-100 transition-all duration-300 shadow-lg shadow-white/10 hover:shadow-white/20 hover:-translate-y-0.5"
        >
          Explore Work
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        <a
          href="/cv.pdf"
          class="inline-flex justify-center items-center gap-2 px-7 py-3.5 bg-slate-800/50 hover:bg-slate-700/50 text-white font-medium rounded-xl border border-slate-700 hover:border-slate-500 transition-all duration-300 backdrop-blur-sm"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          Download CV
        </a>
      </div>

      <!-- Technologies -->
      <div class="reveal pt-12 md:pt-20 border-t border-slate-800/60" style="transition-delay: 400ms;">
        <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-5">Core Stack</p>
        <div class="flex flex-wrap gap-x-8 gap-y-4 items-center opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
          <span class="font-bold text-xl tracking-tight text-white flex items-center gap-1.5"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#eab308" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="m9 15 2 2 4-4"/></svg>Python</span>
          <span class="font-bold text-xl tracking-tight text-white flex items-center gap-1.5"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>SQL</span>
          <span class="font-bold text-xl tracking-tight text-white flex items-center gap-1.5"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Linux</span>
          <span class="font-bold text-xl tracking-tight text-white flex items-center gap-1.5"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="12" x2="12" y1="8" y2="16"/><line x1="8" x2="16" y1="12" y2="12"/></svg>C++</span>
        </div>
      </div>
    </div>
  </div>
</section>

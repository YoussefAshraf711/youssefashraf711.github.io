---
const githubIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`;

const projects = [
  {
    title: "Enterprise AI Data Extractor",
    category: "Data Engineering · AI",
    description:
      "LLM-powered web scraper that converts unstructured web pages into clean, structured JSON. Uses Langchain + Ollama for semantic parsing with Pydantic validation and anti-bot evasion.",
    tech: ["Python", "FastAPI", "Langchain", "Playwright"],
    github: "https://github.com/YoussefAshraf711/ai_web_scraper",
  },
  {
    title: "E-commerce Price Intelligence Pipeline",
    category: "Data Engineering · ETL",
    description:
      "Automated pipeline tracking 120+ product prices daily across 10 categories. Built with modular architecture, PostgreSQL upsert, and Airflow orchestration for production deployment.",
    tech: ["Python", "Airflow", "PostgreSQL", "ETL"],
    github: "https://github.com/YoussefAshraf711/Crypto-Data-ETL-Pipeline",
  },
  {
    title: "AI & Data Science Roadmap",
    category: "Open Source · Education",
    description:
      "Comprehensive, project-based roadmap for becoming a world-class AI & Data Science professional. Covers foundations to production-grade MLOps, available in English & Arabic.",
    tech: ["Education", "Community", "Markdown"],
    github: "https://github.com/YoussefAshraf711/AI-DS-Roadmap",
  },
  {
    title: "CS Specializations Guide",
    category: "Open Source · Education",
    description:
      "Structured learning paths for 13+ Computer Science specializations — from Frontend to Cybersecurity — supporting both English and Arabic learners.",
    tech: ["Education", "Open Source", "Bilingual"],
    github: "https://github.com/YoussefAshraf711/computer-science",
  },
];
---

<section id="projects" class="py-24 md:py-32 px-6 relative">
  <div class="max-w-6xl mx-auto">
    <div class="reveal mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6 pb-6 border-b border-slate-800">
      <div>
        <h2 class="section-heading mb-0">
          <span class="font-mono text-primary text-sm tracking-wider uppercase">03. Work</span>
          <span class="text-3xl md:text-5xl font-bold text-white">
            Featured Projects
          </span>
        </h2>
      </div>
      <p class="text-slate-500 text-sm font-mono pb-2">
        // Selected open source contributions
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {projects.map((project, i) => (
        <div
          class="reveal glass-card p-8 flex flex-col h-full group transition-all duration-500 hover:-translate-y-1.5 border border-slate-700/40 hover:border-slate-500/50 hover:shadow-2xl hover:shadow-primary/5 hover:bg-slate-800/40 relative overflow-hidden"
          style={`transition-delay: ${i * 100}ms;`}
        >
          {/* Header */}
          <div class="flex justify-between items-center mb-6">
            <span class="font-mono text-xs text-primary font-medium tracking-wide bg-primary/10 px-3 py-1 rounded-full border border-primary/20">
              {project.category}
            </span>
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-white transition-colors duration-300 p-2 rounded-full hover:bg-white/10"
              aria-label={`View ${project.title} on GitHub`}
            >
              <span set:html={githubIcon} />
            </a>
          </div>

          {/* Title */}
          <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-primary transition-colors duration-300 tracking-tight">
            {project.title}
          </h3>

          {/* Description */}
          <p class="text-slate-400 text-base mb-8 flex-grow leading-relaxed font-light">
            {project.description}
          </p>

          {/* Tech Tags */}
          <div class="flex flex-wrap gap-2 mt-auto pt-6 border-t border-slate-800 group-hover:border-slate-700 transition-colors duration-300">
            {project.tech.map((t) => (
              <span class="font-mono text-[11px] text-slate-400 uppercase tracking-wider">
                {t}
              </span>
            ))}
          </div>
          
          {/* Subtle Hover gradient */}
          <div class="absolute inset-0 bg-gradient-to-br from-white/[0.01] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-2xl"></div>
        </div>
      ))}
    </div>
  </div>
</section>

---
const skillCategories = [
  {
    title: "Languages",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    skills: ["Python", "C/C++", "SQL", "Bash"],
  },
  {
    title: "Data & AI",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>`,
    skills: ["Pandas", "NumPy", "Scikit-learn", "TensorFlow", "Langchain"],
  },
  {
    title: "Systems & Infra",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/><path d="M12 12h.01"/></svg>`,
    skills: ["Linux/Fedora", "Docker", "Arduino", "Sensors", "PostgreSQL"],
  },
  {
    title: "Tools & Frameworks",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    skills: ["Git/GitHub", "FastAPI", "Airflow", "Playwright", "VS Code"],
  },
];
---

<section id="skills" class="py-24 md:py-32 px-6 relative border-t border-slate-800/50">
  <div class="max-w-6xl mx-auto relative">
    <div class="reveal mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6 pb-6 border-b border-slate-800">
      <div>
        <h2 class="section-heading mb-0">
          <span class="font-mono text-primary text-sm tracking-wider uppercase">02. Arsenal</span>
          <span class="text-3xl md:text-5xl font-bold text-white">
            Technical Arsenal
          </span>
        </h2>
      </div>
      <p class="text-slate-500 text-sm font-mono pb-2">
        // Tools & frameworks I build with
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {skillCategories.map((category, i) => (
        <div
          class={`reveal glass-card p-8 group hover:bg-slate-800/40 border border-slate-700/40 hover:border-slate-600/60 transition-all duration-500 relative overflow-hidden`}
          style={`transition-delay: ${i * 100}ms;`}
        >
          {/* Header */}
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-400 group-hover:text-primary group-hover:border-primary/30 group-hover:bg-primary/5 transition-all duration-300" set:html={category.icon} />
            <h3 class="text-xl font-bold text-white tracking-tight">{category.title}</h3>
          </div>

          {/* Skills */}
          <div class="flex flex-wrap gap-2.5">
            {category.skills.map((skill) => (
              <span class="px-3 py-1.5 bg-slate-900/50 rounded-lg text-sm text-slate-300 border border-slate-800 group-hover:border-slate-600/50 group-hover:text-white transition-all duration-300 drop-shadow-sm">
                {skill}
              </span>
            ))}
          </div>
          
          {/* Gradient overlay on hover */}
          <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        </div>
      ))}
    </div>
  </div>
</section>
